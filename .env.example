# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local

# ── Database ─────────────────────────────────────────────
# MongoDB connection string.
# Local dev default (docker-compose up -d spins this up):
MONGODB_URI=mongodb://localhost:27017/dwcode

# ── AI problem generation ────────────────────────────────
# Google Gemini API key (https://ai.google.dev)
GEMINI_API_KEY=your_gemini_api_key_here

# ── Auth (Clerk — https://clerk.com) ─────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Clerk redirect paths
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# ── App ──────────────────────────────────────────────────
# Public base URL of the app (used for absolute links / OAuth callbacks).
NEXT_PUBLIC_APP_URL=http://localhost:8000

# Clerk userId of the super admin (grants access to /admin).
SUPER_ADMIN_USER_ID=

# ── GitHub integration (optional) ────────────────────────
# OAuth app credentials for pushing playground snippets to GitHub.
# Leave blank to disable the GitHub integration.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── DataWeave compiler backend (optional) ────────────────
# The code-execution engine. Currently the app defaults to the hosted
# service (https://dwlbackend.onrender.com). Uncomment and point this at a
# local DataWeave runtime container if you self-host the compiler.
# DATAWEAVE_BACKEND_URL=http://localhost:4000
